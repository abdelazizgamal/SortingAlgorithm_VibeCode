@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet class="blazor-error-alert">
    <div class="error-content">
        <svg class="error-icon" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
            <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
            <path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533L8.93 6.588zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0z"/>
        </svg>
        <span>An unhandled error has occurred.</span>
        <a href="." class="reload">Reload</a>
        <span class="dismiss">?</span>
    </div>
</div>

<style>
    .page {
        display: flex;
        flex-direction: row;
        min-height: 100vh;
    }

    .sidebar {
        flex: 0 0 280px;
        background: linear-gradient(180deg, #5C4E3A 0%, #3D3D3D 100%);
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
        position: sticky;
        top: 0;
        height: 100vh;
        overflow-y: auto;
        z-index: 1000;
    }

    main {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow-y: auto;
    }

    .content {
        padding: 2rem 2rem;
        flex-grow: 1;
    }

    .blazor-error-alert {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        background: linear-gradient(135deg, #FFE5E5 0%, #FFD1D1 100%);
        border-left: 4px solid #D84C4C;
        padding: 1.5rem;
        border-radius: 10px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
        z-index: 9999;
        max-width: 400px;
        animation: slideInUp 0.4s ease-out;
    }

    .error-content {
        display: flex;
        align-items: center;
        gap: 1rem;
        color: #D84C4C;
    }

    .error-icon {
        width: 24px;
        height: 24px;
        flex-shrink: 0;
    }

    .blazor-error-alert a.reload {
        margin-left: auto;
        padding: 0.5rem 1rem;
        background-color: #D84C4C;
        color: white;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .blazor-error-alert a.reload:hover {
        background-color: #C43D3D;
        box-shadow: 0 4px 12px rgba(216, 76, 76, 0.3);
    }

    .blazor-error-alert .dismiss {
        margin-left: 1rem;
        cursor: pointer;
        font-size: 1.5rem;
        font-weight: 300;
        opacity: 0.7;
        transition: opacity 0.2s ease;
    }

    .blazor-error-alert .dismiss:hover {
        opacity: 1;
    }
</style>
