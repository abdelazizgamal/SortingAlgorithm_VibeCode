@page "/"
@inject IConfiguration Configuration
@inject IJSRuntime JS

<PageTitle>Home - SortHub</PageTitle>

<div class="home-container">
    <div class="hero-section">
        <div class="hero-content">
            <h1>
                <svg class="hero-icon" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M6 12.796V3.204H5V0h5v3.204h-1v9.592h1v3.204H5v-3.204h1zm.5-10a.5.5 0 1 1 0-1 .5.5 0 0 1 0 1z"/>
                </svg>
                Welcome to SortHub
            </h1>
            <p class="hero-subtitle">Explore fast and efficient sorting algorithms with real-time analysis</p>
        </div>
    </div>

    <div class="features-grid">
        <div class="feature-card">
            <div class="feature-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M6 12.796V3.204H5V0h5v3.204h-1v9.592h1v3.204H5v-3.204h1zm.5-10a.5.5 0 1 1 0-1 .5.5 0 0 1 0 1z"/>
                </svg>
            </div>
            <h3>Try Sorting</h3>
            <p>Sort any array using your choice of 8 different algorithms and see results instantly.</p>
            <NavLink href="sorting" class="feature-link">
                Get Started
                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 1 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z"/>
                </svg>
            </NavLink>
        </div>

        <div class="feature-card">
            <div class="feature-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M0 14.5A1.5 1.5 0 0 1 1.5 13h13a1.5 1.5 0 0 1 1.5 1.5v1a1.5 1.5 0 0 1-1.5 1.5h-13A1.5 1.5 0 0 1 0 15.5v-1zm5-13a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V1.5z"/>
                </svg>
            </div>
            <h3>Performance Benchmark</h3>
            <p>Compare execution times between QuickSort and Array.Sort algorithms on large datasets.</p>
            <NavLink href="benchmark" class="feature-link">
                View Benchmark
                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 1 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z"/>
                </svg>
            </NavLink>
        </div>

        <div class="feature-card">
            <div class="feature-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/>
                </svg>
            </div>
            <h3>API Documentation</h3>
            <p>Explore our REST API to integrate sorting algorithms into your applications.</p>
            <a href="http://localhost:5443/Scalar/" class="feature-link" target="_blank">
                View API Docs
                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 1 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z"/>
                </svg>
            </a>
        </div>
    </div>

    <div class="quick-check">
        <h2>
            <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                <path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533L8.93 6.588zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0z"/>
            </svg>
            API Status
        </h2>
        <button class="btn btn-primary" @onclick="CheckHealthAsync">
            @if (isChecking)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
                <span>Checking...</span>
            }
            else
            {
                <span>Check API Health</span>
            }
        </button>

        @if (!string.IsNullOrWhiteSpace(healthMessage))
        {
            <div class="health-status @(isHealthy ? "status-healthy" : "status-unhealthy")">
                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                    @if (isHealthy)
                    {
                        <path d="M10.854 7.146a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708 0l-1.5-1.5a.5.5 0 0 1 .708-.708L7.5 9.793l2.646-2.647a.5.5 0 0 1 .708 0z"/>
                        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                    }
                    else
                    {
                        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                        <path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533L8.93 6.588zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0z"/>
                    }
                </svg>
                <span>@healthMessage</span>
            </div>
        }
    </div>
</div>

@code {
    private string healthMessage = string.Empty;
    private bool isHealthy;
    private bool isChecking;

    private async Task CheckHealthAsync()
    {
        isChecking = true;
        healthMessage = string.Empty;

        var apiBaseUrl = Configuration["ApiSettings:BaseUrl"];
        if (string.IsNullOrWhiteSpace(apiBaseUrl))
        {
            healthMessage = "API base URL is not configured.";
            isHealthy = false;
            isChecking = false;
            return;
        }

        try
        {
            var health = await JS.InvokeAsync<HealthResponse>("sortingApi.health", apiBaseUrl);
            isHealthy = string.Equals(health.Status, "Healthy", StringComparison.OrdinalIgnoreCase);
            healthMessage = isHealthy ? "✓ API is reachable and healthy" : $"✗ API returned status: {health.Status}";
        }
        catch (JSException ex)
        {
            isHealthy = false;
            healthMessage = $"✗ Connection failed: {ex.Message}";
        }
        finally
        {
            isChecking = false;
        }
    }

    private sealed record HealthResponse(string Status);
}

<style>
    .home-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 0;
    }

    .hero-section {
        background: linear-gradient(135deg, rgba(168, 213, 186, 0.15) 0%, rgba(127, 198, 159, 0.1) 100%);
        border-radius: 20px;
        padding: 3rem 2rem;
        margin-bottom: 3rem;
        border: 2px solid var(--primary-light-green);
    }

    .hero-content {
        text-align: center;
    }

    .hero-content h1 {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        font-size: 2.5rem;
        margin-bottom: 1rem;
    }

    .hero-icon {
        width: 48px;
        height: 48px;
        color: var(--accent-green);
    }

    .hero-subtitle {
        font-size: 1.125rem;
        color: var(--text-light);
        max-width: 600px;
        margin: 0 auto;
    }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
        margin-bottom: 3rem;
    }

    .feature-card {
        background: var(--white);
        border-radius: 16px;
        padding: 2rem;
        box-shadow: var(--shadow-md);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        border: 2px solid transparent;
    }

    .feature-card:hover {
        transform: translateY(-8px);
        box-shadow: var(--shadow-lg);
        border-color: var(--primary-green);
    }

    .feature-icon {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, var(--primary-light-green) 0%, var(--primary-green) 100%);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
    }

    .feature-icon svg {
        width: 32px;
        height: 32px;
        color: var(--accent-green);
    }

    .feature-card h3 {
        font-size: 1.25rem;
        margin-bottom: 0.75rem;
        color: var(--dark-brown);
    }

    .feature-card p {
        color: var(--text-light);
        margin-bottom: 1.5rem;
        line-height: 1.6;
    }

    .feature-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--accent-green);
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
        padding: 0.5rem 0;
    }

    .feature-link:hover {
        color: var(--primary-cafe);
        transform: translateX(4px);
    }

    .feature-link svg {
        width: 16px;
        height: 16px;
        transition: transform 0.3s ease;
    }

    .feature-link:hover svg {
        transform: translateX(4px);
    }

    .quick-check {
        background: var(--white);
        border-radius: 16px;
        padding: 2rem;
        box-shadow: var(--shadow-md);
        border: 2px solid var(--primary-light-green);
    }

    .quick-check h2 {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1.5rem;
        font-size: 1.5rem;
    }

    .quick-check svg {
        width: 28px;
        height: 28px;
        color: var(--accent-green);
    }

    .health-status {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-top: 1rem;
        padding: 1rem;
        border-radius: 10px;
    }

    .status-healthy {
        background-color: rgba(107, 174, 109, 0.1);
        color: var(--success);
        border-left: 4px solid var(--success);
    }

    .status-unhealthy {
        background-color: rgba(216, 76, 76, 0.1);
        color: var(--error);
        border-left: 4px solid var(--error);
    }

    .health-status svg {
        width: 24px;
        height: 24px;
        flex-shrink: 0;
    }
</style>
