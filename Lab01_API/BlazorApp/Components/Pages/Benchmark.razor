@page "/benchmark"
@inject IConfiguration Configuration
@inject IJSRuntime JS

<PageTitle>Benchmark - SortHub</PageTitle>

<div class="benchmark-container">
    <div class="benchmark-header">
        <h1>
            <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                <path d="M0 14.5A1.5 1.5 0 0 1 1.5 13h13a1.5 1.5 0 0 1 1.5 1.5v1a1.5 1.5 0 0 1-1.5 1.5h-13A1.5 1.5 0 0 1 0 15.5v-1zm5-13a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V1.5z"/>
            </svg>
            Performance Benchmark
        </h1>
        <p>Compare QuickSort and Array.Sort() on the same large array with 100 iterations.</p>
    </div>

    <div class="benchmark-card">
        <button 
            class="btn btn-primary btn-large"
            @onclick="RunBenchmarkAsync"
            disabled="@isBenchmarking"
        >
            @if (isBenchmarking)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
                <span>Running Benchmark...</span>
            }
            else
            {
                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M11.596 8.697l-6.363 3.692c-.54.313-1.233-.066-1.233-.697V4.308c0-.63.692-1.01 1.233-.696l6.363 3.692a.802.802 0 0 1 0 1.393z"/>
                </svg>
                <span>Start Benchmark</span>
            }
        </button>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                    <path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533L8.93 6.588zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0z"/>
                </svg>
                <strong>Error:</strong> @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = string.Empty"></button>
            </div>
        }

        @if (result is not null)
        {
            <div class="results-grid">
                <div class="benchmark-result quicksort-result">
                    <div class="result-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M6 12.796V3.204H5V0h5v3.204h-1v9.592h1v3.204H5v-3.204h1zm.5-10a.5.5 0 1 1 0-1 .5.5 0 0 1 0 1z"/>
                        </svg>
                    </div>
                    <h3>QuickSort</h3>
                    <div class="algorithm-name">(Recursive, Lomuto Partition)</div>
                    <div class="result-time">@result.QuickSortAverageMilliseconds.ToString("F4")</div>
                    <div class="result-unit">milliseconds</div>
                    <div class="result-meta">Average over @result.Iterations runs on @result.ArraySize elements</div>
                </div>

                <div class="benchmark-result arraysort-result">
                    <div class="result-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M4 15.5a.5.5 0 0 1 .5-.5h11a.5.5 0 0 1 0 1h-11a.5.5 0 0 1-.5-.5zm7-4.5H4.5a.5.5 0 0 1 0-1h6.5a.5.5 0 0 1 0 1zm0-4H4.5a.5.5 0 0 1 0-1h6.5a.5.5 0 0 1 0 1zm0-4H4.5a.5.5 0 0 1 0-1h6.5a.5.5 0 0 1 0 1z"/>
                        </svg>
                    </div>
                    <h3>Array.Sort()</h3>
                    <div class="algorithm-name">(Introspective Sort - Framework)</div>
                    <div class="result-time">@result.ArraySortAverageMilliseconds.ToString("F4")</div>
                    <div class="result-unit">milliseconds</div>
                    <div class="result-meta">Average over @result.Iterations runs on @result.ArraySize elements</div>
                </div>
            </div>

            <div class="comparison-analysis">
                <h2>Comparison Analysis</h2>
                @{
                    var difference = Math.Abs(result.QuickSortAverageMilliseconds - result.ArraySortAverageMilliseconds);
                    var percentage = (difference / Math.Min(result.QuickSortAverageMilliseconds, result.ArraySortAverageMilliseconds)) * 100;
                    var faster = result.QuickSortAverageMilliseconds < result.ArraySortAverageMilliseconds ? "QuickSort" : "Array.Sort()";
                }

                <div class="analysis-item">
                    <div class="analysis-label">Time Difference</div>
                    <div class="analysis-value">@difference.ToString("F4") ms</div>
                </div>

                <div class="analysis-item">
                    <div class="analysis-label">Percentage Difference</div>
                    <div class="analysis-value">@percentage.ToString("F2")%</div>
                </div>

                <div class="analysis-item">
                    <div class="analysis-label">Faster Algorithm</div>
                    <div class="analysis-value">@faster</div>
                </div>

                <div class="analysis-insight">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                        <path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533L8.93 6.588zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0z"/>
                    </svg>
                    <div>
                        <strong>Note:</strong> Array.Sort() is optimized by the .NET Framework using an introspective sort (combination of QuickSort, HeapSort, and InsertionSort) which typically performs faster than a basic QuickSort implementation on most datasets.
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private BenchmarkResult? result;
    private bool isBenchmarking;
    private string errorMessage = string.Empty;

    private async Task RunBenchmarkAsync()
    {
        isBenchmarking = true;
        errorMessage = string.Empty;

        var apiBaseUrl = Configuration["ApiSettings:BaseUrl"];
        if (string.IsNullOrWhiteSpace(apiBaseUrl))
        {
            errorMessage = "API base URL is not configured.";
            isBenchmarking = false;
            return;
        }

        try
        {
            result = await JS.InvokeAsync<BenchmarkResult>("sortingApi.benchmark", apiBaseUrl);
        }
        catch (JSException ex)
        {
            errorMessage = ex.Message;
            result = null;
        }
        finally
        {
            isBenchmarking = false;
        }
    }

    private class BenchmarkResult
    {
        public int Iterations { get; set; }
        public int ArraySize { get; set; }
        public double QuickSortAverageMilliseconds { get; set; }
        public double ArraySortAverageMilliseconds { get; set; }
    }
}

<style>
    .benchmark-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem 0;
    }

    .benchmark-header {
        text-align: center;
        margin-bottom: 2rem;
        animation: fadeIn 0.6s ease-out;
    }

    .benchmark-header h1 {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        font-size: 2.25rem;
        margin-bottom: 0.5rem;
    }

    .benchmark-header h1 svg {
        width: 40px;
        height: 40px;
        color: var(--accent-green);
    }

    .benchmark-header p {
        font-size: 1.125rem;
        color: var(--text-light);
    }

    .benchmark-card {
        background: var(--white);
        border-radius: 16px;
        padding: 2.5rem;
        box-shadow: var(--shadow-md);
        animation: fadeIn 0.6s ease-out 0.1s both;
    }

    .btn-large {
        width: 100%;
        padding: 1rem 2rem;
        font-size: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
    }

    .btn-large svg {
        width: 20px;
        height: 20px;
    }

    .results-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
        margin: 2rem 0;
    }

    .benchmark-result {
        background: linear-gradient(135deg, rgba(168, 213, 186, 0.1) 0%, rgba(127, 198, 159, 0.05) 100%);
        border-radius: 16px;
        padding: 2rem;
        border: 2px solid var(--primary-light-green);
        text-align: center;
        animation: slideInUp 0.4s ease-out;
    }

    .quicksort-result {
        border-left: 6px solid #8B6F47;
    }

    .arraysort-result {
        border-left: 6px solid var(--accent-green);
    }

    .result-icon {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, var(--primary-light-green) 0%, var(--primary-green) 100%);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem;
    }

    .result-icon svg {
        width: 32px;
        height: 32px;
        color: var(--dark-brown);
    }

    .benchmark-result h3 {
        font-size: 1.5rem;
        margin-bottom: 0.25rem;
        color: var(--dark-brown);
    }

    .algorithm-name {
        font-size: 0.875rem;
        color: var(--text-light);
        font-style: italic;
        margin-bottom: 1rem;
    }

    .result-time {
        font-size: 2.5rem;
        font-weight: 700;
        color: var(--accent-green);
        line-height: 1;
    }

    .result-unit {
        font-size: 0.875rem;
        color: var(--text-light);
        font-weight: 600;
        margin-bottom: 1rem;
    }

    .result-meta {
        font-size: 0.8rem;
        color: var(--text-light);
        padding-top: 1rem;
        border-top: 1px solid rgba(168, 213, 186, 0.3);
    }

    .comparison-analysis {
        background: linear-gradient(135deg, #F5F1E8 0%, var(--primary-light-green) 100%);
        border-radius: 16px;
        padding: 2rem;
        border: 2px solid var(--primary-light-green);
        animation: slideInUp 0.4s ease-out 0.1s both;
    }

    .comparison-analysis h2 {
        font-size: 1.5rem;
        margin-top: 0;
        margin-bottom: 1.5rem;
        text-align: center;
        color: var(--dark-brown);
    }

    .analysis-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem;
        background: var(--white);
        border-radius: 10px;
        margin-bottom: 1rem;
        box-shadow: var(--shadow-sm);
    }

    .analysis-label {
        font-weight: 600;
        color: var(--text-dark);
    }

    .analysis-value {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--accent-green);
    }

    .analysis-insight {
        display: flex;
        gap: 1rem;
        padding: 1.5rem;
        background: var(--white);
        border-radius: 10px;
        border-left: 4px solid var(--accent-green);
        margin-top: 1rem;
        animation: slideInLeft 0.4s ease-out;
    }

    .analysis-insight svg {
        width: 24px;
        height: 24px;
        color: var(--accent-green);
        flex-shrink: 0;
        margin-top: 2px;
    }

    .analysis-insight div {
        color: var(--text-dark);
        line-height: 1.6;
    }
</style>
