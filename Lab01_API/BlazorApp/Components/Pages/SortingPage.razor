@page "/sorting"
@inject HttpClient Http
@inject IConfiguration Configuration
@inject IJSRuntime JS
@using System.Text.Json
@using System.Text.Json.Serialization

<PageTitle>Sorting - SortHub</PageTitle>

<div class="sorting-container">
    <div class="sorting-header">
        <h1>
            <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                <path d="M6 12.796V3.204H5V0h5v3.204h-1v9.592h1v3.204H5v-3.204h1zm.5-10a.5.5 0 1 1 0-1 .5.5 0 0 1 0 1z"/>
            </svg>
            Sorting Algorithms
        </h1>
        <p>Select an algorithm and enter comma-separated numbers to sort.</p>
    </div>

    <div class="sorting-card">
        <div class="form-group">
            <label for="numberInput" class="form-label">
                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M4 1.5H3a2 2 0 0 0-2 2V14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V3.5a2 2 0 0 0-2-2h-1v-1a1 1 0 0 0-2 0v1H6v-1a1 1 0 0 0-2 0v1zm0 3a1 1 0 0 0 2 0H4zm8 0a1 1 0 1 0 2 0h-2z"/>
                </svg>
                Numbers (comma-separated)
            </label>
            <input 
                type="text" 
                id="numberInput"
                class="form-control form-input-large" 
                placeholder="e.g., 5, 2, 9, 1, 7, 3"
                @bind="inputNumbers"
                @bind:event="oninput"
            />
            <small class="form-text">e.g., 5, 2, 9, 1, 7 or 42, 17, 81, 3, 99</small>
        </div>

        <div class="form-group">
            <label for="algorithmSelect" class="form-label">
                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M12.854.646a.5.5 0 0 0-.708 0l-7 7-3.5-3.5a.5.5 0 1 0-.708.708l4 4a.5.5 0 0 0 .708 0l7.5-7.5a.5.5 0 0 0-.708-.708zM4.5 12a.5.5 0 0 0 0 1h7a.5.5 0 0 0 0-1h-7z"/>
                </svg>
                Select Algorithm
            </label>
            <select 
                id="algorithmSelect"
                class="form-select form-select-large" 
                @bind="selectedAlgorithm"
                disabled="@(isLoading || algorithms is null || algorithms.Length == 0)"
            >
                <option value="">-- Choose an algorithm --</option>
                @if (algorithms is not null)
                {
                    @foreach (var algo in algorithms)
                    {
                        <option value="@algo">@algo</option>
                    }
                }
            </select>
        </div>

        <div class="button-group">
            <button 
                class="btn btn-primary btn-large" 
                @onclick="SortAsync"
                disabled="@(isLoading || string.IsNullOrWhiteSpace(inputNumbers) || string.IsNullOrWhiteSpace(selectedAlgorithm))"
            >
                @if (isLoading)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                    <span>Sorting...</span>
                }
                else
                {
                    <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M6 12.796V3.204H5V0h5v3.204h-1v9.592h1v3.204H5v-3.204h1zm.5-10a.5.5 0 1 1 0-1 .5.5 0 0 1 0 1z"/>
                    </svg>
                    <span>Sort Now</span>
                }
            </button>
            <button 
                class="btn btn-secondary btn-large" 
                @onclick="ClearForm"
                disabled="@isLoading"
            >
                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M5.5 5a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1H6a.5.5 0 0 1-.5-.5zm0 3a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1H6a.5.5 0 0 1-.5-.5zm0 3a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1H6a.5.5 0 0 1-.5-.5z"/>
                </svg>
                <span>Clear</span>
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                    <path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533L8.93 6.588zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0z"/>
                </svg>
                <strong>Error:</strong> @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = string.Empty"></button>
            </div>
        }

        @if (sortResult is not null)
        {
            <div class="result-section">
                <div class="result-header">
                    <h2>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M10.854 7.146a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708 0l-1.5-1.5a.5.5 0 0 1 .708-.708L7.5 9.793l2.646-2.647a.5.5 0 0 1 .708 0z"/>
                            <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                        </svg>
                        Sorting Complete!
                    </h2>
                </div>

                <div class="result-stats">
                    <div class="stat-item">
                        <div class="stat-label">Algorithm</div>
                        <div class="stat-value">@sortResult.Algorithm</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-label">Execution Time</div>
                        <div class="stat-value">@sortResult.ExecutionTimeMilliseconds.ToString("F4")<span class="stat-unit">ms</span></div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-label">Elements Sorted</div>
                        <div class="stat-value">@(sortResult.SortedArray?.Length ?? 0)</div>
                    </div>
                </div>

                <div class="result-array">
                    <h3>Sorted Array</h3>
                    <div class="array-display">
                        @string.Join(", ", sortResult.SortedArray ?? Array.Empty<int>())
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private string inputNumbers = string.Empty;
    private string selectedAlgorithm = string.Empty;
    private string[] algorithms = Array.Empty<string>();
    private bool isLoading;
    private string errorMessage = string.Empty;
    private SortResult? sortResult;

    private static readonly JsonSerializerOptions JsonOptions = new()
    {
        PropertyNameCaseInsensitive = true,
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
        DefaultIgnoreCondition = JsonIgnoreCondition.WhenWritingNull
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadAlgorithmsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load algorithms: {ex.Message}";
        }
    }

    private async Task LoadAlgorithmsAsync()
    {
        var apiBaseUrl = Configuration["ApiSettings:BaseUrl"];
        if (string.IsNullOrWhiteSpace(apiBaseUrl))
        {
            errorMessage = "API base URL is not configured.";
            return;
        }

        try
        {
            algorithms = await Http.GetFromJsonAsync<string[]>($"{apiBaseUrl}/api/sorting/algorithms")
                ?? Array.Empty<string>();
        }
        catch (HttpRequestException ex)
        {
            errorMessage = $"Failed to load algorithms: {ex.Message}";
            algorithms = Array.Empty<string>();
        }
    }

    private async Task SortAsync()
    {
        errorMessage = string.Empty;
        sortResult = null;

        if (string.IsNullOrWhiteSpace(inputNumbers))
        {
            errorMessage = "Please enter numbers to sort.";
            return;
        }

        if (string.IsNullOrWhiteSpace(selectedAlgorithm))
        {
            errorMessage = "Please select an algorithm.";
            return;
        }

        var numberList = new List<int>();
        try
        {
            var parts = inputNumbers.Split(',');
            foreach (var part in parts)
            {
                var trimmed = part.Trim();
                if (!string.IsNullOrWhiteSpace(trimmed))
                {
                    if (int.TryParse(trimmed, out var number))
                    {
                        numberList.Add(number);
                    }
                    else
                    {
                        errorMessage = $"Invalid number: '{trimmed}'. Please enter valid integers.";
                        return;
                    }
                }
            }

            if (numberList.Count == 0)
            {
                errorMessage = "Please enter at least one number.";
                return;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error parsing numbers: {ex.Message}";
            return;
        }

        isLoading = true;

        try
        {
            var apiBaseUrl = Configuration["ApiSettings:BaseUrl"];
            if (string.IsNullOrWhiteSpace(apiBaseUrl))
            {
                errorMessage = "API base URL is not configured.";
                return;
            }

            var request = new SortRequest
            {
                Numbers = numberList.ToArray(),
                Algorithm = selectedAlgorithm
            };

            var response = await Http.PostAsJsonAsync($"{apiBaseUrl}/api/sorting/sort", request);

            if (response.IsSuccessStatusCode)
            {
                var jsonContent = await response.Content.ReadAsStringAsync();
                sortResult = JsonSerializer.Deserialize<SortResult>(jsonContent, JsonOptions);

                if (sortResult == null)
                {
                    errorMessage = "Failed to parse response from API.";
                }
            }
            else
            {
                var content = await response.Content.ReadAsStringAsync();
                errorMessage = $"Error: {content}";
            }
        }
        catch (HttpRequestException ex)
        {
            errorMessage = $"API request failed: {ex.Message}";
        }
        catch (Exception ex)
        {
            errorMessage = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ClearForm()
    {
        inputNumbers = string.Empty;
        selectedAlgorithm = string.Empty;
        sortResult = null;
        errorMessage = string.Empty;
    }

    private class SortRequest
    {
        public int[]? Numbers { get; set; }
        public string? Algorithm { get; set; }
    }

    private class SortResult
    {
        [JsonPropertyName("SortedArray")]
        public int[]? SortedArray { get; set; }

        [JsonPropertyName("Algorithm")]
        public string? Algorithm { get; set; }

        [JsonPropertyName("ExecutionTimeMilliseconds")]
        public double ExecutionTimeMilliseconds { get; set; }
    }
}

<style>
    .sorting-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem 0;
    }

    .sorting-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .sorting-header h1 {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        font-size: 2.25rem;
        margin-bottom: 0.5rem;
    }

    .sorting-header h1 svg {
        width: 40px;
        height: 40px;
        color: var(--accent-green);
    }

    .sorting-header p {
        font-size: 1.125rem;
        color: var(--text-light);
    }

    .sorting-card {
        background: var(--white);
        border-radius: 16px;
        padding: 2.5rem;
        box-shadow: var(--shadow-md);
    }

    .form-group {
        margin-bottom: 2rem;
    }

    .form-label {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: 600;
        color: var(--dark-brown);
        margin-bottom: 0.75rem;
    }

    .form-label svg {
        width: 20px;
        height: 20px;
        color: var(--accent-green);
    }

    .form-input-large,
    .form-select-large {
        font-size: 1rem;
        padding: 0.875rem 1.25rem;
        border-radius: 12px;
    }

    .form-text {
        display: block;
        margin-top: 0.5rem;
        color: var(--text-light);
        font-size: 0.875rem;
    }

    .button-group {
        display: flex;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .btn-large {
        flex: 1;
        padding: 1rem 2rem;
        font-size: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
    }

    .btn-large svg {
        width: 20px;
        height: 20px;
    }

    .result-section {
        background: linear-gradient(135deg, rgba(168, 213, 186, 0.08) 0%, rgba(127, 198, 159, 0.05) 100%);
        border-radius: 16px;
        padding: 2rem;
        border: 2px solid var(--primary-light-green);
    }

    .result-header {
        display: flex;
        align-items: center;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid var(--primary-light-green);
    }

    .result-header h2 {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 1.5rem;
        margin: 0;
        color: var(--success);
    }

    .result-header svg {
        width: 28px;
        height: 28px;
    }

    .result-stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .stat-item {
        background: var(--white);
        padding: 1.5rem;
        border-radius: 12px;
        text-align: center;
        box-shadow: var(--shadow-sm);
    }

    .stat-label {
        font-size: 0.875rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--text-light);
        margin-bottom: 0.5rem;
    }

    .stat-value {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--accent-green);
    }

    .stat-unit {
        font-size: 0.875rem;
        margin-left: 0.25rem;
    }

    .result-array {
        background: var(--white);
        border-radius: 12px;
        padding: 1.5rem;
        box-shadow: var(--shadow-sm);
    }

    .result-array h3 {
        margin-top: 0;
        margin-bottom: 1rem;
        color: var(--dark-brown);
    }

    .array-display {
        background: linear-gradient(135deg, #F5F1E8 0%, var(--primary-light-green) 100%);
        border-left: 4px solid var(--accent-green);
        padding: 1.25rem;
        border-radius: 8px;
        font-family: 'Courier New', monospace;
        font-size: 0.95rem;
        color: var(--dark-brown);
        word-break: break-word;
        line-height: 1.8;
        max-height: 200px;
        overflow-y: auto;
    }
</style>
